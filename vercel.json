{
  "headers": [
    { "source": "/(.*)", "headers": [ { "key": "Cache-Control", "value": "no-cache, must-revalidate" } ] },
    { "source": "/prices.json", "headers": [ { "key": "Cache-Control", "value": "no-store" } ] },
    { "source": "/products.json", "headers": [ { "key": "Cache-Control", "value": "no-store" } ] },
    { "source": "/app.js", "headers": [ { "key": "Cache-Control", "value": "no-cache, must-revalidate" } ] }
  ]
}
